---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { ApiConsole } from '../components/dashboard/ApiConsole';

const hasJsonPeToken = !!import.meta.env.JSON_PE_TOKEN;
---

<DashboardLayout title="Consola de Consultas API">
	<div class="space-y-12 pb-20">
		<header>
			<h1 class="text-3xl font-black text-white tracking-tight sm:text-4xl flex items-center gap-3">
				<span>Consola de <span class="text-primary">Consultas API</span></span>
				<span class="px-2.5 py-0.5 rounded-md bg-amber-500/10 text-amber-500 text-[10px] font-black border border-amber-500/20 animate-pulse tracking-widest uppercase">
					Beta
				</span>
			</h1>
			<p class="text-zinc-500 mt-2 font-medium max-w-2xl">
				Interactúa con los servicios de consulta.
			</p>
		</header>

		<section>
			<ApiConsole client:load hasJsonPeToken={hasJsonPeToken} />
		</section>
	</div>
</DashboardLayout>
