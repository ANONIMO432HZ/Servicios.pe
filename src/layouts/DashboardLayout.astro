---
import { COPYRIGHT } from '../lib/constants';
import { Navbar } from '../components/layout/Navbar';
// import { Sidebar } from '../components/layout/Sidebar';
import '../styles/globals.css';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;

// Obtener el rol de la sesión desde las cookies de Astro (SSR)
const authCookie = Astro.cookies.get('auth_token')?.value;
const role = authCookie === 'guest-session-token' ? 'guest' : 'admin';

// Inicializar créditos para administradores/registrados si no existen
if (role === 'admin' && !Astro.cookies.has('user_credits')) {
	Astro.cookies.set('user_credits', '50', {
		path: '/',
		httpOnly: false,
		secure: import.meta.env.PROD,
		maxAge: 60 * 60 * 24 * 30
	});
}

const defaultDescription = "GovCheck es el portal unificado experimental de servicios y consultas del Perú. Consulta DNI, RUC, placas vehiculares, licencias de conducir y SOAT de forma consolidada.";
const metaDescription = description || defaultDescription;
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site || 'https://servicios-pe.vercel.app').href;
const finalOgImage = ogImage || new URL('/govcheck-logo.png', Astro.site || 'https://servicios-pe.vercel.app').href;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/png" href="/govcheck-logo.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title} | GovCheck - Servicios y Consultas Perú</title>
		<meta name="title" content={`${title} | GovCheck - Servicios y Consultas Perú`} />
		<meta name="description" content={metaDescription} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={`${title} | GovCheck`} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:image" content={finalOgImage} />
		<meta property="og:site_name" content="GovCheck" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={`${title} | GovCheck`} />
		<meta property="twitter:description" content={metaDescription} />
		<meta property="twitter:image" content={finalOgImage} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased min-h-screen bg-background text-foreground overflow-x-hidden">
		<div class="relative min-h-screen flex flex-col selection:bg-primary/30 selection:text-white">
			<!-- Decorative Background Elements -->
			<div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
				<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-primary/10 blur-[120px] animate-pulse"></div>
				<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-purple-500/5 blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
				<div class="absolute top-[20%] right-[10%] w-[30%] h-[30%] rounded-full bg-blue-400/5 blur-[100px]"></div>
			</div>

			<Navbar client:load role={role} />

			<div class="relative z-10 flex flex-1 overflow-hidden">
				{/* <Sidebar client:load /> */}
				
				<main class="flex-1 w-full overflow-y-auto">
					<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 lg:py-10">
						<slot />
					</div>

					<footer class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-zinc-500 text-[10px] font-bold uppercase tracking-widest mt-auto">
						<div class="flex items-center gap-2">
							<p>{COPYRIGHT}</p>
						</div>

						<div class="flex items-center justify-center">
							<a href="https://github.com/ANONIMO432HZ/Servicios.pe" target="_blank" class="text-slate-400 dark:text-slate-600 hover:text-blue-600 dark:hover:text-blue-400 transition-all group" title="GitHub Profile">
								<svg class="h-4 w-4 opacity-50 group-hover:opacity-100 transition-opacity" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path></svg>
							</a>
						</div>

						<div class="flex gap-6 sm:gap-8">
							<a href="/terms" class="hover:text-primary transition-colors">Términos</a>
							<a href="/privacy" class="hover:text-primary transition-colors">Privacidad</a>
							<a href="/support" class="hover:text-primary transition-colors">Soporte</a>
						</div>
					</footer>
				</main>
			</div>
		</div>
	</body>
</html>

<style is:global>
	:root {
		--font-inter: 'Inter', sans-serif;
		--font-public-sans: 'Public Sans', sans-serif;
	}
	
	body {
		font-family: var(--font-inter);
	}
	
	h1, h2, h3, h4, h5, h6 {
		font-family: var(--font-public-sans);
	}

	/* Custom Scrollbar for Main Content */
	.custom-scrollbar::-webkit-scrollbar {
		width: 4px;
	}
	.custom-scrollbar::-webkit-scrollbar-track {
		background: transparent;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.1);
		border-radius: 10px;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb:hover {
		background: rgba(255, 255, 255, 0.2);
	}
</style>

